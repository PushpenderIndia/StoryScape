[Unit]
Description=gunicorn daemon
After=network.target

[Service]
User=jenkins
Group=www-data
WorkingDirectory=/var/lib/jenkins/workspace/Comify
ExecStart=/var/lib/jenkins/workspace/Comify/venv/bin/gunicorn --access-logfile - --workers 10 --timeout 30 --bind unix:/tmp/gunicorn.sock app:app
Environment="PATH=/var/lib/jenkins/workspace/Comify/venv/bin:/usr/local/bin:/usr/bin:/bin"
# stderr_logfile = /var/lib/jenkins/workspace/Comify/logs/stderr.log
# stdout_logfile = /var/lib/jenkins/workspace/Comify/logs/stdout.log

[Install]
WantedBy=multi-user.target